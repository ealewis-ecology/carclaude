# ---- carclaude config TEMPLATE ----
# Copy to .env and fill in real values:  cp .env.example .env  &&  chmod 600 .env
# The app reads .env (NOT this file). Keep real secrets OUT of .env.example.

# Phone -> Pi auth. A long random string; the PWA asks for it once and stores it.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
APP_TOKEN=change-me-to-a-long-random-string

# Anthropic (the agent). The Agent SDK reads this; the key NEVER goes to the phone.
ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=claude-opus-4-8
# Thinking depth (Opus adaptive thinking): low | medium | high | xhigh | max
# low = fastest replies; max = deepest reasoning. Restart the app to apply.
AGENT_EFFORT=medium

# Where the in-car agent works (point this at YOUR code project), and where "deleted"
# files go. The agent can read/edit/run anything under WORKING_DIR, so choose deliberately.
WORKING_DIR=/path/to/your/project
TRASH_DIR=/path/to/your/project/.trash

# ---- Speech (server-side). Claude has no audio, so STT/TTS come from here. ----
# STT_PROVIDER: openai (whisper) | deepgram
STT_PROVIDER=openai
STT_MODEL=whisper-1
# TTS_PROVIDER: elevenlabs | openai
TTS_PROVIDER=elevenlabs

# OpenAI — used for Whisper STT (and OpenAI TTS if TTS_PROVIDER=openai)
OPENAI_API_KEY=
TTS_MODEL=tts-1
TTS_VOICE=alloy

# Deepgram — only if STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# ElevenLabs — TTS. Get a voice id from your ElevenLabs Voice Library.
# eleven_turbo_v2_5 (quality) or eleven_flash_v2_5 (lowest latency, good for driving).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Server bind. Keep on localhost; cloudflared connects to it locally.
HOST=127.0.0.1
PORT=8787
